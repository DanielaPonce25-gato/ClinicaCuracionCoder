# Puerto del servidor
PORT=3000

#  ESTA ES LA CLAVE SECRETA

# Secreto para firmar la cookie de sesión 
SESSION_SECRET=tu_session_secret

# Secreto para firmar el Token
JWT_SECRET=tu_jwt_secret

# Clave de Google para OAuth 
GOOGLE_CLIENT_ID=tu_google_client_id

# Entorno: development | production
NODE_ENV=development

# Tipo de almacenamiento de sesiones: memory | file | mongo
SESSION_STORE=mongo


# Puede ser local: mongodb://localhost:27017

# O de Atlas: 
MONGODB_URI= mongodb+srv://usuario:password@cluster.mongodb.net/mi_base
